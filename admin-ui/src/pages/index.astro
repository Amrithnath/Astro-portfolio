---
const title = 'Wedding Admin';

const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL || 'http://127.0.0.1:8787';
const adminDebugEmail = import.meta.env.PUBLIC_ADMIN_DEBUG_EMAIL || '';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body>
    <main class="shell">
      <section class="app-shell">
        <aside class="sidebar">
          <div>
            <div class="eyebrow">admin.amrithnath.dev</div>
            <h1>Wedding Admin</h1>
            <p class="lede">Live control room for wedding copy, rollout state, provider config, and preview verification.</p>
          </div>

          <nav class="nav-stack" aria-label="Admin sections">
            <a href="#overview" class="nav-link is-active">Overview</a>
            <a href="#wedding-copy" class="nav-link">Wedding Copy</a>
            <a href="#theme" class="nav-link">Wedding Theme</a>
            <a href="#uploads" class="nav-link">Upload Policy</a>
            <a href="#storage" class="nav-link">Storage Provider</a>
          </nav>
        </aside>

        <section class="workspace">
          <header class="topbar">
            <div>
              <div class="status-label">API target</div>
              <strong id="api-target">{apiBaseUrl}</strong>
            </div>
            <span id="top-status" class="badge">Loading live config</span>
          </header>

          <div id="error-banner" class="banner banner-error" hidden></div>
          <div id="success-banner" class="banner banner-success" hidden></div>

          <div class="content-grid">
            <section class="panel panel-stack">
              <article id="overview" class="section-card section-card-wide">
                <div class="section-index">01</div>
                <div class="section-body">
                  <div class="section-heading-row">
                    <div>
                      <h2>Overview</h2>
                      <p>Current admin session and rollout state from the Go API.</p>
                    </div>
                    <button id="refresh-button" class="secondary-button" type="button">Refresh</button>
                  </div>

                  <div class="stats-grid">
                    <section class="mini-panel">
                      <span class="status-label">Admin session</span>
                      <strong id="session-name">Checking access</strong>
                      <p id="session-detail">Waiting for `/api/admin/session`.</p>
                    </section>

                    <section class="mini-panel">
                      <span class="status-label">Guest route</span>
                      <strong id="rollout-state">Loading</strong>
                      <p id="rollout-detail">Reading enabled state from wedding public config.</p>
                    </section>

                    <section class="mini-panel">
                      <span class="status-label">Upload backend</span>
                      <strong id="storage-state">Loading</strong>
                      <p id="storage-detail">Reading provider validation snapshot.</p>
                    </section>
                  </div>
                </div>
              </article>

              <article id="wedding-copy" class="section-card section-card-wide">
                <div class="section-index">02</div>
                <div class="section-body">
                  <div class="section-heading-row">
                    <div>
                      <h2>Wedding Copy</h2>
                      <p>Edit the guest-facing copy that powers `/wedding` right now.</p>
                    </div>
                    <button id="save-button" class="primary-button" type="button">Save wedding copy</button>
                  </div>

                  <form id="wedding-copy-form" class="form-grid">
                    <label class="checkbox-row">
                      <input id="enabled" name="enabled" type="checkbox" />
                      <span>Wedding uploads enabled</span>
                    </label>

                    <label>
                      <span>Names</span>
                      <input id="names" name="names" type="text" placeholder="Amrith & Arjun" />
                    </label>

                    <label>
                      <span>Eyebrow</span>
                      <input id="eyebrow" name="eyebrow" type="text" placeholder="wedding.media://dropbox" />
                    </label>

                    <label>
                      <span>Headline</span>
                      <input id="headline" name="headline" type="text" placeholder="Share the moments you caught." />
                    </label>

                    <label class="field-wide">
                      <span>Subheadline</span>
                      <textarea id="subheadline" name="subheadline" rows="3"></textarea>
                    </label>

                    <label class="field-wide">
                      <span>Dropzone copy</span>
                      <textarea id="dropzoneCopy" name="dropzoneCopy" rows="3"></textarea>
                    </label>

                    <label class="field-wide">
                      <span>Supporting copy</span>
                      <textarea id="supportingCopy" name="supportingCopy" rows="3"></textarea>
                    </label>

                    <label>
                      <span>Success title</span>
                      <input id="successTitle" name="successTitle" type="text" />
                    </label>

                    <label class="field-wide">
                      <span>Success message</span>
                      <textarea id="successMessage" name="successMessage" rows="3"></textarea>
                    </label>

                    <label class="field-wide">
                      <span>Closed message</span>
                      <textarea id="closedMessage" name="closedMessage" rows="3"></textarea>
                    </label>
                  </form>
                </div>
              </article>

              <article id="theme" class="section-card section-card-wide">
                <div class="section-index">03</div>
                <div class="section-body">
                  <div class="section-heading-row">
                    <div>
                      <h2>Wedding Theme</h2>
                      <p>Manage the palette and presentation tokens currently backing the guest upload experience.</p>
                    </div>
                    <button id="save-theme-button" class="primary-button" type="button">Save theme</button>
                  </div>

                  <form id="theme-form" class="form-grid">
                    <label>
                      <span>Preset</span>
                      <input id="themePreset" name="themePreset" type="text" placeholder="terminal-romance" />
                    </label>

                    <label>
                      <span>Typography preset</span>
                      <input id="themeTypographyPreset" name="themeTypographyPreset" type="text" placeholder="mono-editorial" />
                    </label>

                    <label>
                      <span>Primary accent</span>
                      <input id="themePrimaryAccent" name="themePrimaryAccent" type="text" placeholder="#63f0b6" />
                    </label>

                    <label>
                      <span>Secondary accent</span>
                      <input id="themeSecondaryAccent" name="themeSecondaryAccent" type="text" placeholder="#7dd3fc" />
                    </label>

                    <label>
                      <span>Surface style</span>
                      <input id="themeSurfaceStyle" name="themeSurfaceStyle" type="text" placeholder="glass-dark" />
                    </label>

                    <label>
                      <span>Button style</span>
                      <input id="themeButtonStyle" name="themeButtonStyle" type="text" placeholder="pill" />
                    </label>

                    <label>
                      <span>Hero asset ID</span>
                      <input id="themeHeroAssetId" name="themeHeroAssetId" type="text" placeholder="hero-asset-id" />
                    </label>

                    <label>
                      <span>Texture asset ID</span>
                      <input id="themeTextureAssetId" name="themeTextureAssetId" type="text" placeholder="texture-asset-id" />
                    </label>
                  </form>
                </div>
              </article>

              <article id="uploads" class="section-card section-card-wide">
                <div class="section-index">04</div>
                <div class="section-body">
                  <div class="section-heading-row">
                    <div>
                      <h2>Upload Policy</h2>
                      <p>Control live upload availability, limits, session lifetime, and MIME policy.</p>
                    </div>
                    <button id="save-upload-policy-button" class="primary-button" type="button">Save upload policy</button>
                  </div>

                  <form id="upload-policy-form" class="form-grid">
                    <label class="checkbox-row">
                      <input id="policyUploadsEnabled" name="policyUploadsEnabled" type="checkbox" />
                      <span>Uploads enabled</span>
                    </label>

                    <label>
                      <span>Max file bytes</span>
                      <input id="policyMaxFileBytes" name="policyMaxFileBytes" type="text" inputmode="numeric" placeholder="10737418240" />
                    </label>

                    <label>
                      <span>Max active uploads per IP</span>
                      <input id="policyMaxActiveUploadsPerIp" name="policyMaxActiveUploadsPerIp" type="text" inputmode="numeric" placeholder="12" />
                    </label>

                    <label>
                      <span>Upload session TTL ms</span>
                      <input id="policyUploadSessionTtlMs" name="policyUploadSessionTtlMs" type="text" inputmode="numeric" placeholder="86400000" />
                    </label>

                    <label class="field-wide">
                      <span>Allowed MIME types</span>
                      <textarea id="policyAllowedMimeTypes" name="policyAllowedMimeTypes" rows="4" placeholder="image/jpeg&#10;video/mp4"></textarea>
                    </label>

                    <label class="field-wide">
                      <span>Maintenance message</span>
                      <textarea id="policyMaintenanceMessage" name="policyMaintenanceMessage" rows="3"></textarea>
                    </label>
                  </form>
                </div>
              </article>

              <article id="storage" class="section-card section-card-wide">
                <div class="section-index">05</div>
                <div class="section-body">
                  <div class="section-heading-row">
                    <div>
                      <h2>Storage Provider</h2>
                      <p>Switch providers, stage provider-specific settings, and verify real backend readiness before guests can upload.</p>
                    </div>
                    <div class="button-row-inline">
                      <button id="validate-storage-button" class="secondary-button" type="button">Validate provider</button>
                      <button id="save-storage-button" class="primary-button" type="button">Save provider</button>
                    </div>
                  </div>

                  <form id="storage-form" class="form-grid">
                    <label>
                      <span>Provider</span>
                      <select id="storageProvider" name="storageProvider">
                        <option value="STORAGE_PROVIDER_KIND_GOOGLE_DRIVE">Google Drive</option>
                        <option value="STORAGE_PROVIDER_KIND_GOOGLE_PHOTOS">Google Photos</option>
                      </select>
                    </label>

                    <label class="checkbox-row">
                      <input id="storagePhotosEnabled" name="storagePhotosEnabled" type="checkbox" />
                      <span>Google Photos ingest enabled</span>
                    </label>

                    <div id="drive-fields" class="stack-group field-wide">
                      <label>
                        <span>Drive folder ID</span>
                        <input id="storageDriveFolderId" name="storageDriveFolderId" type="text" placeholder="folder-id" />
                      </label>

                      <label>
                        <span>Drive folder label</span>
                        <input id="storageDriveFolderLabel" name="storageDriveFolderLabel" type="text" placeholder="Wedding Uploads" />
                      </label>
                    </div>

                    <div id="photos-fields" class="stack-group field-wide">
                      <label>
                        <span>Photos album ID</span>
                        <input id="storagePhotosAlbumId" name="storagePhotosAlbumId" type="text" placeholder="album-id" />
                      </label>

                      <label>
                        <span>Photos album title</span>
                        <input id="storagePhotosAlbumTitle" name="storagePhotosAlbumTitle" type="text" placeholder="Reception Highlights" />
                      </label>
                    </div>
                  </form>

                  <p id="storage-validation-result" class="inline-message" hidden></p>
                  <div id="storage-readiness-summary" class="storage-readiness-summary"></div>
                </div>
              </article>
            </section>

            <aside id="preview-panel" class="panel preview-panel">
              <div class="preview-header">
                <span class="status-label">Live Preview</span>
                <span id="preview-chip" class="preview-chip">mobile</span>
              </div>
              <div class="preview-phone">
                <div class="preview-screen">
                  <p id="preview-eyebrow" class="preview-eyebrow">wedding.media://dropbox</p>
                  <h2 id="preview-title" class="preview-title">Share the moments you caught.</h2>
                  <p id="preview-copy" class="preview-copy">Drop in the photos and videos from your phone. Uploads stay private and go straight into our wedding archive.</p>
                  <div id="preview-dropzone" class="preview-dropzone">
                    <span>Tap to choose files</span>
                    <strong id="preview-dropzone-copy">Photos, HEIC, MOV, and large videos are all welcome.</strong>
                  </div>
                  <p id="preview-supporting-copy" class="preview-supporting-copy">Uploads run one file at a time for better reliability on mobile networks.</p>
                  <div id="preview-closed" class="preview-closed" hidden>
                    <span>Uploads unavailable</span>
                    <strong id="preview-closed-message">Uploads are paused right now. Please try again later.</strong>
                  </div>
                </div>
              </div>
            </aside>
          </div>
        </section>
      </section>
    </main>

    <script is:inline define:vars={{ apiBaseUrl, adminDebugEmail }}>
      const state = {
        session: null,
        weddingPublic: null,
        theme: null,
        uploadPolicy: null,
        storage: null,
        isSavingWeddingPublic: false,
        isSavingTheme: false,
        isSavingUploadPolicy: false,
        isSavingStorage: false,
        isValidatingStorage: false,
      };

      const elements = {
        topStatus: document.getElementById('top-status'),
        refreshButton: document.getElementById('refresh-button'),
        saveWeddingCopyButton: document.getElementById('save-button'),
        saveThemeButton: document.getElementById('save-theme-button'),
        saveUploadPolicyButton: document.getElementById('save-upload-policy-button'),
        saveStorageButton: document.getElementById('save-storage-button'),
        validateStorageButton: document.getElementById('validate-storage-button'),
        errorBanner: document.getElementById('error-banner'),
        successBanner: document.getElementById('success-banner'),
        sessionName: document.getElementById('session-name'),
        sessionDetail: document.getElementById('session-detail'),
        rolloutState: document.getElementById('rollout-state'),
        rolloutDetail: document.getElementById('rollout-detail'),
        storageState: document.getElementById('storage-state'),
        storageDetail: document.getElementById('storage-detail'),
        storageValidationResult: document.getElementById('storage-validation-result'),
        storageReadinessSummary: document.getElementById('storage-readiness-summary'),
        driveFields: document.getElementById('drive-fields'),
        photosFields: document.getElementById('photos-fields'),
        previewPanel: document.getElementById('preview-panel'),
        previewDropzone: document.getElementById('preview-dropzone'),
        previewEyebrow: document.getElementById('preview-eyebrow'),
        previewTitle: document.getElementById('preview-title'),
        previewCopy: document.getElementById('preview-copy'),
        previewDropzoneCopy: document.getElementById('preview-dropzone-copy'),
        previewSupportingCopy: document.getElementById('preview-supporting-copy'),
        previewClosed: document.getElementById('preview-closed'),
        previewClosedMessage: document.getElementById('preview-closed-message'),
      };

      const weddingCopyForm = document.getElementById('wedding-copy-form');
      const weddingCopyFields = {
        enabled: document.getElementById('enabled'),
        names: document.getElementById('names'),
        eyebrow: document.getElementById('eyebrow'),
        headline: document.getElementById('headline'),
        subheadline: document.getElementById('subheadline'),
        dropzoneCopy: document.getElementById('dropzoneCopy'),
        supportingCopy: document.getElementById('supportingCopy'),
        successTitle: document.getElementById('successTitle'),
        successMessage: document.getElementById('successMessage'),
        closedMessage: document.getElementById('closedMessage'),
      };

      const themeForm = document.getElementById('theme-form');
      const themeFields = {
        preset: document.getElementById('themePreset'),
        typographyPreset: document.getElementById('themeTypographyPreset'),
        primaryAccent: document.getElementById('themePrimaryAccent'),
        secondaryAccent: document.getElementById('themeSecondaryAccent'),
        surfaceStyle: document.getElementById('themeSurfaceStyle'),
        buttonStyle: document.getElementById('themeButtonStyle'),
        heroAssetId: document.getElementById('themeHeroAssetId'),
        textureAssetId: document.getElementById('themeTextureAssetId'),
      };

      const uploadPolicyForm = document.getElementById('upload-policy-form');
      const uploadPolicyFields = {
        uploadsEnabled: document.getElementById('policyUploadsEnabled'),
        maxFileBytes: document.getElementById('policyMaxFileBytes'),
        maxActiveUploadsPerIp: document.getElementById('policyMaxActiveUploadsPerIp'),
        uploadSessionTtlMs: document.getElementById('policyUploadSessionTtlMs'),
        allowedMimeTypes: document.getElementById('policyAllowedMimeTypes'),
        maintenanceMessage: document.getElementById('policyMaintenanceMessage'),
      };

      const storageForm = document.getElementById('storage-form');
      const storageFields = {
        provider: document.getElementById('storageProvider'),
        photosEnabled: document.getElementById('storagePhotosEnabled'),
        driveFolderId: document.getElementById('storageDriveFolderId'),
        driveFolderLabel: document.getElementById('storageDriveFolderLabel'),
        photosAlbumId: document.getElementById('storagePhotosAlbumId'),
        photosAlbumTitle: document.getElementById('storagePhotosAlbumTitle'),
      };

      function getHeaders() {
        const headers = { Accept: 'application/json' };
        if (adminDebugEmail) {
          headers['X-Admin-Debug-Email'] = adminDebugEmail;
        }
        return headers;
      }

      async function apiFetch(path, init = {}) {
        const response = await fetch(`${apiBaseUrl}${path}`, {
          ...init,
          credentials: 'include',
          headers: {
            ...getHeaders(),
            ...(init.headers || {}),
          },
        });

        const isJSON = response.headers.get('content-type')?.includes('application/json');
        const payload = isJSON ? await response.json() : null;

        if (!response.ok) {
          const errorMessage = payload?.error || `Request failed with status ${response.status}`;
          throw new Error(errorMessage);
        }

        return payload;
      }

      function setBanner(element, message) {
        if (!message) {
          element.hidden = true;
          element.textContent = '';
          return;
        }

        element.hidden = false;
        element.textContent = message;
      }

      function formatUnixTimestamp(value) {
        const unix = Number(value);
        if (!Number.isFinite(unix) || unix <= 0) {
          return 'Not available';
        }

        return new Date(unix * 1000).toLocaleString();
      }

      function formatBytes(value) {
        const bytes = Number(value);
        if (!Number.isFinite(bytes) || bytes <= 0) {
          return '0 B';
        }

        const units = ['B', 'KB', 'MB', 'GB', 'TB'];
        const exponent = Math.min(Math.floor(Math.log(bytes) / Math.log(1024)), units.length - 1);
        const scaled = bytes / Math.pow(1024, exponent);
        return `${scaled >= 10 || exponent === 0 ? scaled.toFixed(0) : scaled.toFixed(1)} ${units[exponent]}`;
      }

      function formatValue(value) {
        if (Array.isArray(value)) {
          return value.length > 0 ? value.join(', ') : 'None';
        }

        if (typeof value === 'boolean') {
          return value ? 'Enabled' : 'Disabled';
        }

        if (value === '' || value === null || value === undefined) {
          return 'Not set';
        }

        return String(value);
      }

      function renderDetailList(container, items) {
        container.replaceChildren(
          ...items.flatMap((item) => {
            const term = document.createElement('dt');
            term.textContent = item.label;
            const detail = document.createElement('dd');
            detail.textContent = item.value;
            return [term, detail];
          }),
        );
      }

      function parseInteger(value, fallback = 0) {
        const normalized = String(value ?? '').trim();
        if (normalized === '') {
          return fallback;
        }

        const parsed = Number.parseInt(normalized, 10);
        return Number.isFinite(parsed) ? parsed : fallback;
      }

      function applyWeddingCopyForm(config) {
        weddingCopyFields.enabled.checked = Boolean(config.enabled);
        weddingCopyFields.names.value = config.names || '';
        weddingCopyFields.eyebrow.value = config.eyebrow || '';
        weddingCopyFields.headline.value = config.headline || '';
        weddingCopyFields.subheadline.value = config.subheadline || '';
        weddingCopyFields.dropzoneCopy.value = config.dropzoneCopy || '';
        weddingCopyFields.supportingCopy.value = config.supportingCopy || '';
        weddingCopyFields.successTitle.value = config.successTitle || '';
        weddingCopyFields.successMessage.value = config.successMessage || '';
        weddingCopyFields.closedMessage.value = config.closedMessage || '';
      }

      function readWeddingCopyForm() {
        return {
          enabled: weddingCopyFields.enabled.checked,
          names: weddingCopyFields.names.value.trim(),
          eyebrow: weddingCopyFields.eyebrow.value.trim(),
          headline: weddingCopyFields.headline.value.trim(),
          subheadline: weddingCopyFields.subheadline.value.trim(),
          dropzoneCopy: weddingCopyFields.dropzoneCopy.value.trim(),
          supportingCopy: weddingCopyFields.supportingCopy.value.trim(),
          successTitle: weddingCopyFields.successTitle.value.trim(),
          successMessage: weddingCopyFields.successMessage.value.trim(),
          closedMessage: weddingCopyFields.closedMessage.value.trim(),
        };
      }

      function applyThemeForm(config) {
        themeFields.preset.value = config.preset || '';
        themeFields.typographyPreset.value = config.typographyPreset || '';
        themeFields.primaryAccent.value = config.primaryAccent || '';
        themeFields.secondaryAccent.value = config.secondaryAccent || '';
        themeFields.surfaceStyle.value = config.surfaceStyle || '';
        themeFields.buttonStyle.value = config.buttonStyle || '';
        themeFields.heroAssetId.value = config.heroAssetId || '';
        themeFields.textureAssetId.value = config.textureAssetId || '';
      }

      function readThemeForm() {
        return {
          preset: themeFields.preset.value.trim(),
          typographyPreset: themeFields.typographyPreset.value.trim(),
          primaryAccent: themeFields.primaryAccent.value.trim(),
          secondaryAccent: themeFields.secondaryAccent.value.trim(),
          surfaceStyle: themeFields.surfaceStyle.value.trim(),
          buttonStyle: themeFields.buttonStyle.value.trim(),
          heroAssetId: themeFields.heroAssetId.value.trim(),
          textureAssetId: themeFields.textureAssetId.value.trim(),
        };
      }

      function applyUploadPolicyForm(config) {
        uploadPolicyFields.uploadsEnabled.checked = Boolean(config.uploadsEnabled);
        uploadPolicyFields.maxFileBytes.value = config.maxFileBytes || '';
        uploadPolicyFields.maxActiveUploadsPerIp.value = config.maxActiveUploadsPerIp || '';
        uploadPolicyFields.uploadSessionTtlMs.value = config.uploadSessionTtlMs || '';
        uploadPolicyFields.allowedMimeTypes.value = Array.isArray(config.allowedMimeTypes)
          ? config.allowedMimeTypes.join('\n')
          : '';
        uploadPolicyFields.maintenanceMessage.value = config.maintenanceMessage || '';
      }

      function readUploadPolicyForm() {
        return {
          uploadsEnabled: uploadPolicyFields.uploadsEnabled.checked,
          maxFileBytes: parseInteger(uploadPolicyFields.maxFileBytes.value),
          maxActiveUploadsPerIp: parseInteger(uploadPolicyFields.maxActiveUploadsPerIp.value),
          uploadSessionTtlMs: parseInteger(uploadPolicyFields.uploadSessionTtlMs.value),
          allowedMimeTypes: uploadPolicyFields.allowedMimeTypes.value
            .split('\n')
            .map((value) => value.trim())
            .filter(Boolean),
          maintenanceMessage: uploadPolicyFields.maintenanceMessage.value.trim(),
        };
      }

      function applyStorageForm(config) {
        storageFields.provider.value = config.provider || 'STORAGE_PROVIDER_KIND_GOOGLE_DRIVE';
        storageFields.photosEnabled.checked = Boolean(config.photosEnabled);
        storageFields.driveFolderId.value = config.driveFolderId || '';
        storageFields.driveFolderLabel.value = config.driveFolderLabel || '';
        storageFields.photosAlbumId.value = config.photosAlbumId || '';
        storageFields.photosAlbumTitle.value = config.photosAlbumTitle || '';
        syncStorageFormVisibility();
      }

      function readStorageForm() {
        return {
          provider: storageFields.provider.value,
          photosEnabled: storageFields.photosEnabled.checked,
          driveFolderId: storageFields.driveFolderId.value.trim(),
          driveFolderLabel: storageFields.driveFolderLabel.value.trim(),
          photosAlbumId: storageFields.photosAlbumId.value.trim(),
          photosAlbumTitle: storageFields.photosAlbumTitle.value.trim(),
        };
      }

      function syncStorageFormVisibility() {
        const isDrive = storageFields.provider.value === 'STORAGE_PROVIDER_KIND_GOOGLE_DRIVE';
        elements.driveFields.hidden = !isDrive;
        elements.photosFields.hidden = isDrive;
      }

      function getStorageProviderLabel(provider) {
        if (provider === 'STORAGE_PROVIDER_KIND_GOOGLE_PHOTOS') {
          return 'Google Photos';
        }

        if (provider === 'STORAGE_PROVIDER_KIND_GOOGLE_DRIVE') {
          return 'Google Drive';
        }

        return 'Not set';
      }

      function getStorageReadinessSnapshot(storage = state.storage) {
        if (!storage) {
          return {
            guestState: 'Unavailable',
            guestDetail: 'Storage provider config could not be loaded.',
            backendState: 'Unavailable',
            backendDetail: 'Storage provider config could not be loaded.',
            validationTone: 'warning',
            validationMessage: '',
            summaryLines: [],
          };
        }

        const providerLabel = getStorageProviderLabel(storage.provider);
        const validatedAtLabel = formatUnixTimestamp(storage.validatedAtUnix);
        const hasDriveFolder = Boolean(storage.driveFolderId);
        const hasValidationError = Boolean(storage.lastValidationError);
        const isValidated = Boolean(storage.validatedAtUnix) && !hasValidationError;

        if (storage.provider === 'STORAGE_PROVIDER_KIND_GOOGLE_PHOTOS') {
          return {
            guestState: 'Blocked on provider',
            guestDetail: 'Google Photos is selected, but guest upload ingest still requires the future OAuth album flow.',
            backendState: 'Needs new flow',
            backendDetail: 'Google Photos cannot power guest uploads yet. Switch to Drive or build the Photos admin OAuth path.',
            validationTone: 'warning',
            validationMessage: storage.lastValidationError || 'Google Photos configuration is stored, but it is not a guest-ready provider yet.',
            summaryLines: [
              `Selected provider: ${providerLabel}`,
              `Album title: ${storage.photosAlbumTitle || 'Not set'}`,
              `Photos ingest flag: ${storage.photosEnabled ? 'Enabled' : 'Disabled'}`,
            ],
          };
        }

        if (!hasDriveFolder) {
          return {
            guestState: 'Blocked on storage',
            guestDetail: 'The wedding page can open, but guests cannot start uploads until a Drive folder ID is set.',
            backendState: 'Folder missing',
            backendDetail: 'Add a Google Drive folder ID, then run validation so the API can confirm access.',
            validationTone: 'warning',
            validationMessage: 'Drive folder ID is required before guest uploads can be enabled safely.',
            summaryLines: [
              `Selected provider: ${providerLabel}`,
              'Drive folder ID: Not set',
              'Validation: Never run',
            ],
          };
        }

        if (hasValidationError) {
          return {
            guestState: 'Blocked on validation',
            guestDetail: 'The wedding page may be enabled, but upload init will currently reject guests because Drive validation is failing.',
            backendState: 'Needs attention',
            backendDetail: storage.lastValidationError,
            validationTone: 'warning',
            validationMessage: storage.lastValidationError,
            summaryLines: [
              `Selected provider: ${providerLabel}`,
              `Drive folder: ${storage.driveFolderLabel || storage.driveFolderId}`,
              `Last successful check: ${validatedAtLabel}`,
            ],
          };
        }

        if (!isValidated) {
          return {
            guestState: 'Blocked until validated',
            guestDetail: 'The wedding page copy can be live, but upload init will not start until Drive validation runs successfully at least once.',
            backendState: 'Awaiting validation',
            backendDetail: 'Run “Validate provider” to confirm the folder is reachable by the configured service account.',
            validationTone: 'warning',
            validationMessage: 'Drive storage is configured but has not been validated yet.',
            summaryLines: [
              `Selected provider: ${providerLabel}`,
              `Drive folder: ${storage.driveFolderLabel || storage.driveFolderId}`,
              'Validation: Never run',
            ],
          };
        }

        return {
          guestState: 'Backend ready',
          guestDetail: 'Drive storage is validated. Guests can upload whenever the page and upload policy are enabled.',
          backendState: 'Validated',
          backendDetail: `Drive access last verified ${validatedAtLabel}.`,
          validationTone: 'positive',
          validationMessage: `Drive folder access verified for ${storage.driveFolderLabel || storage.driveFolderId}.`,
          summaryLines: [
            `Selected provider: ${providerLabel}`,
            `Drive folder: ${storage.driveFolderLabel || storage.driveFolderId}`,
            `Last verified: ${validatedAtLabel}`,
          ],
        };
      }

      function renderSession() {
        if (!state.session) {
          elements.sessionName.textContent = 'No admin session';
          elements.sessionDetail.textContent = 'Cloudflare Access or local debug auth is required before config calls can succeed.';
          return;
        }

        elements.sessionName.textContent = state.session.admin?.displayName || state.session.admin?.email || 'Signed in';
        elements.sessionDetail.textContent = `${state.session.accessEmail} · step-up ${state.session.requiresStepUp ? 'required' : 'not required'} · expires ${formatUnixTimestamp(state.session.expiresAtUnix)}`;
      }

      function renderWeddingPublic() {
        if (!state.weddingPublic) {
          elements.rolloutState.textContent = 'Unavailable';
          elements.rolloutDetail.textContent = 'Wedding public config could not be loaded.';
          return;
        }

        applyWeddingCopyForm(state.weddingPublic);
        syncPreview();

        const storageReadiness = getStorageReadinessSnapshot();
        const pageEnabled = Boolean(state.weddingPublic.enabled);
        const uploadPolicyEnabled = Boolean(state.uploadPolicy?.uploadsEnabled);

        if (!pageEnabled) {
          elements.rolloutState.textContent = 'Closed to guests';
          elements.rolloutDetail.textContent = state.weddingPublic.closedMessage || 'The wedding page is currently closed from the public-config switch.';
          return;
        }

        if (!uploadPolicyEnabled) {
          elements.rolloutState.textContent = 'Paused by policy';
          elements.rolloutDetail.textContent = state.uploadPolicy?.maintenanceMessage || 'The wedding page is enabled, but the upload policy currently pauses guest uploads.';
          return;
        }

        if (storageReadiness.backendState !== 'Validated') {
          elements.rolloutState.textContent = 'Visible but blocked';
          elements.rolloutDetail.textContent = storageReadiness.guestDetail;
          return;
        }

        elements.rolloutState.textContent = 'Open for uploads';
        elements.rolloutDetail.textContent = 'Guests currently see the upload composer on `/wedding`, and upload init is ready to accept files.';
      }

      function renderTheme() {
        if (!state.theme) {
          return;
        }

        applyThemeForm(state.theme);
        syncThemePreview();
      }

      function renderUploadPolicy() {
        if (!state.uploadPolicy) {
          return;
        }

        applyUploadPolicyForm(state.uploadPolicy);
        syncPreview();
      }

      function renderStorage() {
        if (!state.storage) {
          elements.storageState.textContent = 'Unavailable';
          elements.storageDetail.textContent = 'Storage provider config could not be loaded.';
          elements.storageReadinessSummary.replaceChildren();
          return;
        }

        applyStorageForm(state.storage);

        const readiness = getStorageReadinessSnapshot();
        elements.storageState.textContent = readiness.backendState;
        elements.storageDetail.textContent = readiness.backendDetail;
        setStorageValidationResult(readiness.validationMessage, readiness.validationTone === 'positive');
        elements.storageReadinessSummary.replaceChildren(
          ...readiness.summaryLines.map((line) => {
            const item = document.createElement('p');
            item.className = 'storage-summary-line';
            item.textContent = line;
            return item;
          }),
        );
      }

      function syncThemePreview() {
        const theme = readThemeForm();
        if (theme.primaryAccent) {
          elements.previewDropzone.style.borderColor = theme.primaryAccent;
        } else {
          elements.previewDropzone.style.removeProperty('border-color');
        }

        if (theme.secondaryAccent) {
          elements.previewEyebrow.style.color = theme.secondaryAccent;
        } else {
          elements.previewEyebrow.style.removeProperty('color');
        }

        if (theme.primaryAccent) {
          elements.previewPanel.style.borderColor = `${theme.primaryAccent}33`;
        } else {
          elements.previewPanel.style.removeProperty('border-color');
        }
      }

      function syncPreview() {
        const config = readWeddingCopyForm();
        elements.previewEyebrow.textContent = config.eyebrow || 'wedding.media://dropbox';
        elements.previewTitle.textContent = config.headline || 'Share the moments you caught.';
        elements.previewCopy.textContent = config.subheadline || 'Drop in the photos and videos from your phone. Uploads stay private and go straight into our wedding archive.';
        elements.previewDropzoneCopy.textContent = config.dropzoneCopy || 'Photos, HEIC, MOV, and large videos are all welcome.';
        elements.previewSupportingCopy.textContent = config.supportingCopy || 'Uploads run one file at a time for better reliability on mobile networks.';

        const uploadsOpen = Boolean(config.enabled) && Boolean(state.uploadPolicy?.uploadsEnabled);
        elements.previewClosed.hidden = uploadsOpen;
        const uploadPolicyDraft = readUploadPolicyForm();
        elements.previewClosedMessage.textContent = uploadPolicyDraft.maintenanceMessage || config.closedMessage || 'Uploads are paused right now. Please try again later.';
      }

      function setStorageValidationResult(message, isPositive = false) {
        if (!message) {
          elements.storageValidationResult.hidden = true;
          elements.storageValidationResult.textContent = '';
          elements.storageValidationResult.dataset.tone = '';
          return;
        }

        elements.storageValidationResult.hidden = false;
        elements.storageValidationResult.textContent = message;
        elements.storageValidationResult.dataset.tone = isPositive ? 'positive' : 'warning';
      }

      function renderAll() {
        renderSession();
        renderWeddingPublic();
        renderTheme();
        renderUploadPolicy();
        renderStorage();
      }

      async function loadDashboard() {
        setBanner(elements.errorBanner, '');
        setBanner(elements.successBanner, '');
        elements.topStatus.textContent = 'Loading live config';

        try {
          const [sessionPayload, weddingPayload, themePayload, uploadPolicyPayload, storagePayload] = await Promise.all([
            apiFetch('/api/admin/session'),
            apiFetch('/api/admin/config/wedding-public'),
            apiFetch('/api/admin/config/wedding-theme'),
            apiFetch('/api/admin/config/upload-policy'),
            apiFetch('/api/admin/config/storage-provider'),
          ]);

          state.session = sessionPayload.session;
          state.weddingPublic = weddingPayload.config;
          state.theme = themePayload.config;
          state.uploadPolicy = uploadPolicyPayload.config;
          state.storage = storagePayload.config;
          renderAll();
          elements.topStatus.textContent = 'Live config connected';
        } catch (error) {
          state.session = null;
          state.weddingPublic = null;
          state.theme = null;
          state.uploadPolicy = null;
          state.storage = null;
          renderAll();
          elements.topStatus.textContent = 'Live config unavailable';
          setBanner(elements.errorBanner, error instanceof Error ? error.message : 'Dashboard load failed.');
        }
      }

      async function saveWeddingCopy() {
        if (state.isSavingWeddingPublic) {
          return;
        }

        state.isSavingWeddingPublic = true;
        elements.saveWeddingCopyButton.disabled = true;
        elements.saveWeddingCopyButton.textContent = 'Saving...';
        setBanner(elements.errorBanner, '');
        setBanner(elements.successBanner, '');

        try {
          const payload = await apiFetch('/api/admin/config/wedding-public', {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ config: readWeddingCopyForm() }),
          });

          state.weddingPublic = payload.config;
          renderWeddingPublic();
          elements.topStatus.textContent = 'Wedding copy saved';
          setBanner(elements.successBanner, 'Wedding public config saved to the API.');
        } catch (error) {
          setBanner(elements.errorBanner, error instanceof Error ? error.message : 'Save failed.');
        } finally {
          state.isSavingWeddingPublic = false;
          elements.saveWeddingCopyButton.disabled = false;
          elements.saveWeddingCopyButton.textContent = 'Save wedding copy';
        }
      }

      async function saveTheme() {
        if (state.isSavingTheme) {
          return;
        }

        state.isSavingTheme = true;
        elements.saveThemeButton.disabled = true;
        elements.saveThemeButton.textContent = 'Saving...';
        setBanner(elements.errorBanner, '');
        setBanner(elements.successBanner, '');

        try {
          const payload = await apiFetch('/api/admin/config/wedding-theme', {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ config: readThemeForm() }),
          });

          state.theme = payload.config;
          renderTheme();
          elements.topStatus.textContent = 'Wedding theme saved';
          setBanner(elements.successBanner, 'Wedding theme config saved to the API.');
        } catch (error) {
          setBanner(elements.errorBanner, error instanceof Error ? error.message : 'Save failed.');
        } finally {
          state.isSavingTheme = false;
          elements.saveThemeButton.disabled = false;
          elements.saveThemeButton.textContent = 'Save theme';
        }
      }

      async function saveUploadPolicy() {
        if (state.isSavingUploadPolicy) {
          return;
        }

        state.isSavingUploadPolicy = true;
        elements.saveUploadPolicyButton.disabled = true;
        elements.saveUploadPolicyButton.textContent = 'Saving...';
        setBanner(elements.errorBanner, '');
        setBanner(elements.successBanner, '');

        try {
          const payload = await apiFetch('/api/admin/config/upload-policy', {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ config: readUploadPolicyForm() }),
          });

          state.uploadPolicy = payload.config;
          renderUploadPolicy();
          renderWeddingPublic();
          elements.topStatus.textContent = 'Upload policy saved';
          setBanner(elements.successBanner, 'Upload policy saved to the API.');
        } catch (error) {
          setBanner(elements.errorBanner, error instanceof Error ? error.message : 'Save failed.');
        } finally {
          state.isSavingUploadPolicy = false;
          elements.saveUploadPolicyButton.disabled = false;
          elements.saveUploadPolicyButton.textContent = 'Save upload policy';
        }
      }

      async function validateStorageProvider() {
        if (state.isValidatingStorage) {
          return;
        }

        state.isValidatingStorage = true;
        elements.validateStorageButton.disabled = true;
        elements.validateStorageButton.textContent = 'Validating...';
        setBanner(elements.errorBanner, '');

        try {
          const payload = await apiFetch('/api/admin/config/storage-provider/validate', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ config: readStorageForm() }),
          });

          elements.topStatus.textContent = payload.valid ? 'Storage validation passed' : 'Storage validation needs attention';
          setStorageValidationResult(payload.validationMessage, payload.valid);
        } catch (error) {
          setBanner(elements.errorBanner, error instanceof Error ? error.message : 'Validation failed.');
        } finally {
          state.isValidatingStorage = false;
          elements.validateStorageButton.disabled = false;
          elements.validateStorageButton.textContent = 'Validate provider';
        }
      }

      async function saveStorageProvider() {
        if (state.isSavingStorage) {
          return;
        }

        state.isSavingStorage = true;
        elements.saveStorageButton.disabled = true;
        elements.saveStorageButton.textContent = 'Saving...';
        setBanner(elements.errorBanner, '');
        setBanner(elements.successBanner, '');

        try {
          const payload = await apiFetch('/api/admin/config/storage-provider', {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ config: readStorageForm() }),
          });

          state.storage = payload.config;
          renderStorage();
          renderWeddingPublic();
          elements.topStatus.textContent = 'Storage provider saved';
          setBanner(elements.successBanner, 'Storage provider config saved to the API.');
        } catch (error) {
          setBanner(elements.errorBanner, error instanceof Error ? error.message : 'Save failed.');
        } finally {
          state.isSavingStorage = false;
          elements.saveStorageButton.disabled = false;
          elements.saveStorageButton.textContent = 'Save provider';
        }
      }

      weddingCopyForm.addEventListener('input', syncPreview);
      themeForm.addEventListener('input', syncThemePreview);
      uploadPolicyForm.addEventListener('input', syncPreview);
      storageForm.addEventListener('input', syncStorageFormVisibility);
      elements.refreshButton.addEventListener('click', loadDashboard);
      elements.saveWeddingCopyButton.addEventListener('click', saveWeddingCopy);
      elements.saveThemeButton.addEventListener('click', saveTheme);
      elements.saveUploadPolicyButton.addEventListener('click', saveUploadPolicy);
      elements.validateStorageButton.addEventListener('click', validateStorageProvider);
      elements.saveStorageButton.addEventListener('click', saveStorageProvider);
      loadDashboard();
    </script>
  </body>
</html>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    min-height: 100%;
    background: #0a0d14;
    color: #edf2f7;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  :global(*) {
    box-sizing: border-box;
  }

  .shell {
    min-height: 100vh;
    padding: 24px;
  }

  .app-shell {
    display: grid;
    gap: 20px;
  }

  .sidebar,
  .panel {
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 20px;
    background: rgba(15, 23, 42, 0.9);
  }

  .sidebar {
    padding: 32px;
  }

  .eyebrow {
    color: #7dd3fc;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 12px 0;
    font-size: clamp(2rem, 6vw, 3rem);
  }

  .lede,
  p,
  dd {
    margin: 0;
    color: #cbd5e1;
    line-height: 1.7;
  }

  .nav-stack {
    display: grid;
    gap: 10px;
    margin-top: 28px;
  }

  .nav-link {
    color: #cbd5e1;
    text-decoration: none;
    padding: 12px 14px;
    border-radius: 12px;
    background: rgba(30, 41, 59, 0.45);
    border: 1px solid transparent;
  }

  .nav-link.is-active,
  .nav-link:hover,
  .nav-link:focus-visible {
    border-color: rgba(125, 211, 252, 0.4);
    color: #f8fafc;
  }

  .workspace {
    display: grid;
    gap: 20px;
  }

  .topbar {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: start;
  }

  .status-label {
    display: block;
    color: #7dd3fc;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .badge,
  .preview-chip {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 12px;
    background: rgba(125, 211, 252, 0.12);
    color: #7dd3fc;
  }

  .banner {
    padding: 14px 16px;
    border-radius: 16px;
    border: 1px solid transparent;
  }

  .banner-error {
    background: rgba(127, 29, 29, 0.3);
    border-color: rgba(248, 113, 113, 0.35);
    color: #fecaca;
  }

  .banner-success {
    background: rgba(20, 83, 45, 0.32);
    border-color: rgba(74, 222, 128, 0.35);
    color: #bbf7d0;
  }

  .content-grid {
    display: grid;
    gap: 20px;
  }

  .panel-stack {
    display: grid;
    gap: 14px;
    padding: 20px;
  }

  .section-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 16px;
    padding: 18px;
    border-radius: 16px;
    background: rgba(30, 41, 59, 0.45);
  }

  .section-card-wide {
    grid-template-columns: auto minmax(0, 1fr);
  }

  .section-body {
    display: grid;
    gap: 18px;
    min-width: 0;
  }

  .section-index {
    color: #7dd3fc;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding-top: 4px;
  }

  .section-heading-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: start;
  }

  h2 {
    margin: 0 0 8px;
    font-size: 1.15rem;
  }

  .stats-grid {
    display: grid;
    gap: 14px;
  }

  .mini-panel {
    padding: 16px;
    border-radius: 16px;
    background: rgba(15, 23, 42, 0.66);
    border: 1px solid rgba(148, 163, 184, 0.14);
  }

  .mini-panel strong {
    display: block;
    font-size: 1rem;
    margin-bottom: 6px;
  }

  .form-grid {
    display: grid;
    gap: 14px;
  }

  label {
    display: grid;
    gap: 8px;
    color: #e2e8f0;
    font-size: 0.95rem;
  }

  label span {
    color: #cbd5e1;
  }

  input,
  textarea,
  button {
    font: inherit;
  }

  input[type='text'],
  select,
  textarea {
    width: 100%;
    border-radius: 12px;
    border: 1px solid rgba(148, 163, 184, 0.2);
    background: rgba(15, 23, 42, 0.82);
    color: #f8fafc;
    padding: 12px 14px;
  }

  textarea {
    resize: vertical;
    min-height: 96px;
  }

  select {
    appearance: none;
  }

  input[type='checkbox'] {
    width: 18px;
    height: 18px;
    accent-color: #7dd3fc;
  }

  .checkbox-row {
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 12px;
  }

  .field-wide {
    grid-column: 1 / -1;
  }

  .stack-group {
    display: grid;
    gap: 14px;
  }

  .button-row-inline {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .inline-message {
    padding: 12px 14px;
    border-radius: 14px;
    background: rgba(30, 41, 59, 0.56);
    border: 1px solid rgba(148, 163, 184, 0.18);
  }

  .inline-message[data-tone='positive'] {
    color: #bbf7d0;
    border-color: rgba(74, 222, 128, 0.35);
    background: rgba(20, 83, 45, 0.22);
  }

  .inline-message[data-tone='warning'] {
    color: #fecaca;
    border-color: rgba(248, 113, 113, 0.35);
    background: rgba(127, 29, 29, 0.2);
  }

  .storage-readiness-summary {
    display: grid;
    gap: 8px;
    padding: 14px 16px;
    border-radius: 14px;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(148, 163, 184, 0.14);
  }

  .storage-summary-line {
    margin: 0;
    color: #cbd5e1;
    font-size: 0.95rem;
  }

  .primary-button,
  .secondary-button {
    border-radius: 12px;
    border: 1px solid transparent;
    padding: 12px 16px;
    cursor: pointer;
    transition: border-color 120ms ease, transform 120ms ease, opacity 120ms ease;
  }

  .primary-button {
    background: linear-gradient(135deg, #7dd3fc, #63f0b6);
    color: #03111c;
    font-weight: 700;
  }

  .secondary-button {
    background: rgba(15, 23, 42, 0.82);
    color: #edf2f7;
    border-color: rgba(148, 163, 184, 0.22);
  }

  .primary-button:hover,
  .secondary-button:hover,
  .primary-button:focus-visible,
  .secondary-button:focus-visible {
    transform: translateY(-1px);
  }

  .primary-button:disabled,
  .secondary-button:disabled {
    cursor: not-allowed;
    opacity: 0.6;
    transform: none;
  }

  .detail-list {
    display: grid;
    grid-template-columns: minmax(0, 180px) minmax(0, 1fr);
    gap: 8px 14px;
    margin: 0;
  }

  dt {
    color: #7dd3fc;
    font-size: 0.9rem;
  }

  .preview-panel {
    padding: 20px;
  }

  .preview-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .preview-phone {
    width: min(100%, 320px);
    margin: 0 auto;
    border-radius: 28px;
    padding: 12px;
    background: linear-gradient(180deg, #0f172a, #020617);
    border: 1px solid rgba(148, 163, 184, 0.16);
  }

  .preview-screen {
    border-radius: 22px;
    padding: 18px;
    background:
      radial-gradient(circle at top, rgba(99, 240, 182, 0.18), transparent 24%),
      linear-gradient(180deg, #08111f 0%, #050811 48%, #03050a 100%);
    min-height: 520px;
  }

  .preview-eyebrow {
    color: #63f0b6;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 11px;
  }

  .preview-title {
    margin: 10px 0;
    font-size: 1.8rem;
    line-height: 1.1;
  }

  .preview-copy,
  .preview-supporting-copy {
    color: #cbd5e1;
  }

  .preview-dropzone {
    display: grid;
    gap: 8px;
    margin-top: 18px;
    padding: 18px;
    border-radius: 20px;
    border: 1px dashed rgba(99, 240, 182, 0.38);
    background: rgba(15, 23, 42, 0.72);
  }

  .preview-dropzone span,
  .preview-closed span {
    color: #63f0b6;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .preview-dropzone strong,
  .preview-closed strong {
    line-height: 1.5;
  }

  .preview-closed {
    display: grid;
    gap: 8px;
    margin-top: 18px;
    padding: 16px;
    border-radius: 18px;
    background: rgba(127, 29, 29, 0.22);
    border: 1px solid rgba(248, 113, 113, 0.24);
  }

  @media (min-width: 52rem) {
    .stats-grid,
    .form-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 72rem) {
    .app-shell {
      grid-template-columns: 280px minmax(0, 1fr);
      align-items: start;
    }

    .sidebar {
      position: sticky;
      top: 24px;
    }

    .content-grid {
      grid-template-columns: minmax(0, 1fr) 360px;
      align-items: start;
    }
  }

  @media (max-width: 51.99rem) {
    .topbar,
    .section-heading-row {
      flex-direction: column;
    }

    .detail-list {
      grid-template-columns: 1fr;
    }
  }
</style>
