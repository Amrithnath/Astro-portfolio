---
import BaseLayout from '../layouts/BaseLayout.astro';
import TerminalCommand from '../components/TerminalCommand.astro';
---

<BaseLayout title="Not Found | Amrith" description="The requested page does not exist." currentPage="/404">
  <div class="terminal-view">
    <div class="terminal-container">
      <div class="window">
        <div class="terminal">
          <TerminalCommand command="ls /requested/path" />
          <div class="output">
            <div class="command-output">ls: cannot access '/requested/path': No such file or directory</div>
          </div>

          <TerminalCommand command="echo fallback.paths" />
          <div class="output not-found-links">
            <a href="/">/</a>
            <a href="/about">/about</a>
            <a href="/projects">/projects</a>
            <a href="/contact">/contact</a>
          </div>

          <div class="prompt"><span class="user">amrith</span><span class="symbol">@</span><span class="host">portfolio</span><span class="symbol">:</span><span class="path">~</span><span class="symbol">$</span><span class="cursor">█</span></div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .theme-terminal .not-found-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .theme-terminal .not-found-links a {
    color: var(--terminal-cyan);
    text-decoration: none;
  }

  .theme-terminal .not-found-links a:hover,
  .theme-terminal .not-found-links a:focus-visible {
    color: var(--terminal-green);
  }
</style>
